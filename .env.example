# ── Supabase (OBLIGATORIO) ─────────────────────────────────────────
# Crea un proyecto en https://supabase.com/dashboard y copia estos
# valores desde Project Settings → API.
# ⚠️ Usa la key "service_role" (secreta, solo server). NUNCA la anon.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OpenAI (OBLIGATORIO para respuestas de IA) ─────────────────────
# Crea una key en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Modelo recomendado: gpt-4o-mini (~US$0.15 por millón de tokens).
OPENAI_MODEL=gpt-4o-mini
